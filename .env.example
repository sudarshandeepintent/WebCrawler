# copy this file to .env and fill in the values you need.
# all variables are optional — the app works without any of them.

# ── cache ─────────────────────────────────────────────────────────────────────

# Redis connection string. if not set, falls back to in-process LRU cache.
# for local Redis:        redis://localhost:6379
# for Upstash (TLS):      rediss://default:PASSWORD@host.upstash.io:6379
REDIS_URL=

# how long a cached result lives before expiring (seconds). default 3600 = 1 hour.
CACHE_TTL=3600

# max entries in the in-memory cache before LRU eviction kicks in.
# ignored when REDIS_URL is set.
CACHE_MAX=500

# key prefix used in Redis — useful if you share a Redis instance across projects.
CACHE_PREFIX=webcrawler:

# ── server ────────────────────────────────────────────────────────────────────

# port the server listens on. Cloud Run sets this automatically.
PORT=8000

# ── cors ──────────────────────────────────────────────────────────────────────

# comma-separated list of allowed browser origins.
# set to * to allow all origins (fine for local dev and demos).
# leave empty if the UI and API are served from the same origin.
CORS_ORIGINS=*
